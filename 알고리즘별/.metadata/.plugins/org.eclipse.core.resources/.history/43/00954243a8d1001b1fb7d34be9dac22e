package yogiyo03;

import java.util.HashSet;

public class Main {
	public static void main(String[] args) {
		int[] A = { 1, 2, 3, 2 };
		int[] dp = new int[A.length];
		HashSet<Integer> setNum = new HashSet<>();
		for (int i = 0; i < A.length; i++) {
			setNum.add(A[i]);
			dp[i] = setNum.size();
		}
	}
}
