import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		int[] arr = new int[n];
		for (int i = 0; i < n; i++) {
			arr[i] = sc.nextInt();
		}
		int[] asc_dp = new int[n];
		int[] desc_dp = new int[n];
		int ans = 2;
		int count = 0;
		for (int i = 1; i < n; i++) {
			if (arr[i] <= arr[i - 1])
				count++;
			else
				break;
		}
		if (count >= 3) {
			ans = Math.max(ans, count);
		}

		count = 0;
		for (int i = 0; i < n - 1; i++) {
			if (arr[i + 1] >= arr[i])
				count++;
			else
				break;
		}
		if (count >= 3) {
			ans = Math.max(ans, count);
		}
		System.out.println(ans);
	}
}
