import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		int[] dp = new int[100001];
		dp[2] = dp[5] = 1;
		for (int i = 6; i <= n; i++) {
			if (dp[i - 2] != 0) {
				dp[i] = Math.min(dp[i], dp[i - 2] + 1);
			}
			if (dp[i - 5] != 0) {
				dp[i] = Math.min(dp[i], dp[i - 5] + 1);
			}
		}
		System.out.println(dp[n]);
	}
}
