import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int t = sc.nextInt();
		while (t-- > 0) {
			int n = sc.nextInt();
			int[] arr = new int[n];
			for (int i = 0; i < n; i++) {
				arr[i] = sc.nextInt();
			}
			int m = sc.nextInt();
			int[] dp = new int[m + 1];
			for (int i = 1; i * arr[0] <= m; i++) {
				dp[i * arr[0]]++;
			}
			for (int i = 1; i < n; i++) {
				for (int j = 1; j <= m; j++) {
					if (j - arr[i] >= 0) {
						dp[j] += dp[j - arr[i]];
						System.out.println("j " + (j - arr[i]));
					}
					if (j % arr[i] == 0) {
						dp[j]++;
					}
				}
			}
			System.out.println(dp[m]);
		}
	}
}
