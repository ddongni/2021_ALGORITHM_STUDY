package BJ10826_ĮĮšļģŠÄĄžö4;

import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		long[] dp = new long[10001];
		dp[1] = 1;
		int n = sc.nextInt();
		for (int i = 2; i <= n; i++) {
			dp[i] = dp[i - 1] + dp[i - 2];
		}
		System.out.println(dp[n]);
	}
}
